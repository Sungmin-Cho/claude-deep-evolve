{
  "schema_version": "1.0",
  "stdout": {
    "raw_command": "node child-command.cjs emit 'accuracy: 0.8' 'latency: 9'",
    "timeout": 17,
    "direction": "minimize",
    "baseline_score": 10,
    "metrics": {
      "accuracy": { "pattern": "^accuracy:\\s+([\\d.]+)", "weight": 0.25 },
      "latency": { "pattern": "^latency:\\s+([\\d.]+)", "weight": 0.75 }
    }
  },
  "test_runner": {
    "test_command": "node child-command.cjs emit 'Tests: 4 passed, 5 total'",
    "coverage_command": "node child-command.cjs emit 'TOTAL 80%'",
    "lint_command": "node child-command.cjs emit '0 errors 2 warnings'",
    "timeout": 19,
    "weights": { "test_pass_rate": 0.5, "coverage": 0.3, "lint": 0.2 }
  },
  "scenario": {
    "target_dir": ".",
    "weights": { "reliability": 1 },
    "scenarios": [
      {
        "name": "literal_output",
        "category": "reliability",
        "description": "recognized literal scenario",
        "test_command": "node child-command.cjs exit 0 expected",
        "expected_exit": 0,
        "expected_output": "expected"
      }
    ]
  }
}
