  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sungmin-Cho/claude-deep-evolve.git"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "deep-evolve",
    "autoresearch",
