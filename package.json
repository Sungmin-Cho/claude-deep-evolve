{
  "name": "@deep-evolve/deep-evolve",
  "version": "3.5.0",
  "description": "Autonomous Experimentation Protocol — goal-driven experiment loops that systematically improve any project through measured code modifications; skill-based entry (cross-platform: Claude Code / Codex / Copilot / Gemini)",
