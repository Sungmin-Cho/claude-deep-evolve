{
  "description": "Protect immutable files during deep-evolve experiment runs (v2.2.2: TOOL_NAME guard + initializing-status bypass)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/protect-readonly.sh",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
