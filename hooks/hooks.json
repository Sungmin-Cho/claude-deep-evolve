{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/scripts/protect-readonly.cjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\hooks\\scripts\\protect-readonly.cjs\" ; exit $LASTEXITCODE",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
